FROM docker.io/fedora:42

ENV PIP_BREAK_SYSTEM_PACKAGES=1 \
    PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

RUN dnf install -y python3.13 python3.13-pip curl && \
    alternatives --install /usr/bin/python python /usr/bin/python3.13 1 && \
    python -m ensurepip --upgrade && \
    pip3 install --no-cache-dir --upgrade 'pip>=26.0' 'setuptools>=78.1.1' && \
    pip3 install --no-cache-dir \
        mcp \
        websockets \
        pyyaml \
        prometheus-client \
        requests \
        python-logging-loki \
        pika \
        confluent-kafka \
        pulsar-client && \
    dnf clean all && \
    rm -rf /var/cache/dnf

WORKDIR /app

COPY trustgraph-base/trustgraph/ /app/trustgraph/
COPY trustgraph-mcp/trustgraph/mcp_server/ /app/trustgraph/mcp_server/
COPY trustgraph_legal/ /app/trustgraph_legal/
COPY resources/legal_rules/ /app/resources/legal_rules/
COPY resources/ontologies/ /app/resources/ontologies/
COPY tests/fixtures/legal-ocr/ /app/tests/fixtures/legal-ocr/
COPY scripts/recova_mcp/ /app/scripts/recova_mcp/
COPY scripts/legal_ontology/ /app/scripts/legal_ontology/

CMD ["sh", "-c", "exec python -m trustgraph.mcp_server.legal_only --host 0.0.0.0 --port \"${PORT:-8000}\" --repo-root /app"]
